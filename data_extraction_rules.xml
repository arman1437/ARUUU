<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ data extraction rules.
    Block all cloud backup AND device-to-device transfer of sensitive data.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <exclude domain="sharedpref" path="aruuu_secure_creds.xml" />
        <exclude domain="database" path="aruuu.db" />
        <exclude domain="file" path="intruder_selfies" />
        <exclude domain="file" path="datastore" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="aruuu_secure_creds.xml" />
        <exclude domain="database" path="aruuu.db" />
        <exclude domain="file" path="intruder_selfies" />
        <exclude domain="file" path="datastore" />
    </device-transfer>
</data-extraction-rules>
