<?xml version="1.0" encoding="utf-8"?>
<!--
    ARUUU Network Security Config
    Privacy-first: no external server communication.
    All data stays on-device. Cleartext traffic blocked entirely.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
